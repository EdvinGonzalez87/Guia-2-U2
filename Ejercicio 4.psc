Algoritmo sin_titulo
	Definir opcion Como Entero
	
    Escribir "===== MENÚ ====="
    Escribir "1 Hamburguesa?"
    Escribir "2 Pizza?"
    Escribir "3 Pollo frito?"
    Escribir "4 Ensalada?"
    Escribir "Seleccione una opción:"
    Leer opcion
	
    Segun opcion Hacer
        1:
            Escribir "Usted ha pedido una Hamburguesa"
        2:
            Escribir "Usted ha pedido una Pizza"
        3:
            Escribir "Usted ha pedido Pollo frito"
        4:
            Escribir "Usted ha pedido una Ensalada"
        De Otro Modo:
            Escribir "Opción no válida"
    FinSegun
FinAlgoritmo
